<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="GyroMouse.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="GyroMouse">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="16,24,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical">
            <TextBlock Text="GyroMouse — PC Receiver" 
                   FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <Border Background="#252525" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Local IP Address: " 
                           FontFamily="Consolas" 
                           Foreground="Gray" 
                           VerticalAlignment="Center"/>
                    <TextBlock x:Name="IpAddressText" 
                           Text="192.168.1.XX" 
                           FontSize="20" 
                           FontFamily="Consolas"
                           FontWeight="Bold" 
                           Foreground="{ThemeResource SystemAccentColor}" 
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Button x:Name="TestMouseBtn" Content="Test Mouse (+50,+50)" 
                HorizontalAlignment="Stretch"
                Click="TestMouseBtn_Click" Margin="0,0,0,16"/>

            <Border Background="#1A1A1A" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="RECEIVER STATUS" FontSize="10" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,8"/>
                    <TextBlock x:Name="LiveStatsBox" FontFamily="Consolas" FontSize="14" Foreground="#4CAF50" Text="Waiting for data..."/>
                </StackPanel>
            </Border>

            <TextBlock Text="System Logs:" FontWeight="Bold" Margin="0,0,0,8"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#0D0D0D" CornerRadius="4" Padding="8">
            <TextBlock x:Name="LogBox" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" Foreground="Gray"/>
        </ScrollViewer>
    </Grid>
</Window>